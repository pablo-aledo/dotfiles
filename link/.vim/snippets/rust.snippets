	}

snippet tn-clientstream "streaming del cliente hacia el servidor" b
	async fn ${1:metodo_client_stream}(
		&self,
		request: tonic::Request<tonic::Streaming<${2:PeticionProto}>>,
	) -> Result<tonic::Response<${3:RespuestaProto}>, tonic::Status> {
		let mut stream = request.into_inner();
		let mut acumulado = Vec::new();

		while let Some(mensaje) = stream.message().await? {
			acumulado.push(mensaje);
		}
		${0:todo!()}
	}

snippet tn-bidistream "streaming bidireccional cliente-servidor" b
	type ${1:MiStream} = std::pin::Pin<Box<dyn futures::Stream<Item = Result<${2:RespuestaProto}, tonic::Status>> + Send>>;

	async fn ${3:metodo_bidi}(
		&self,
		request: tonic::Request<tonic::Streaming<${4:PeticionProto}>>,
	) -> Result<tonic::Response<Self::${1:MiStream}>, tonic::Status> {
		let mut entrada = request.into_inner();
		let (tx, rx) = tokio::sync::mpsc::channel(${5:32});

		tokio::spawn(async move {
			while let Ok(Some(mensaje)) = entrada.message().await {
				${0:todo!()}
			}
		});

		Ok(tonic::Response::new(Box::pin(tokio_stream::wrappers::ReceiverStream::new(rx))))
	}

