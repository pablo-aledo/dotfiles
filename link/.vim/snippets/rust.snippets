	struct ${5:BusDeEventos} {
		emisor: tokio::sync::mpsc::Sender<${1:Evento}>,
	}

	impl ${5:BusDeEventos} {
		async fn publicar(&self, evento: ${1:Evento}) {
			${0:self.emisor.send(evento).await.ok();}
		}
	}

snippet pat-actor "actor: estado propio de una tarea, se muta solo via mensajes (patron de tokio)" b
	enum ${1:Mensaje} {
		${2:Consultar} { respuesta: tokio::sync::oneshot::Sender<${3:Tipo}> },
		${4:Actualizar}(${3:Tipo}),
	}

	struct ${5:Actor} {
		receptor: tokio::sync::mpsc::Receiver<${1:Mensaje}>,
		estado: ${3:Tipo},
	}

	impl ${5:Actor} {
		async fn ejecutar(mut self) {
			while let Some(mensaje) = self.receptor.recv().await {
				match mensaje {
					${1:Mensaje}::${2:Consultar} { respuesta } => {
						let _ = respuesta.send(self.estado.clone());
					}
					${1:Mensaje}::${4:Actualizar}(nuevo) => {
						self.estado = nuevo;
					}
				}
			}
			${0}
		}
	}

snippet pat-actorhandle "handle publico para comunicarse con un actor (oculta el canal)"
	#[derive(Clone)]
	struct ${1:ActorHandle} {
		emisor: tokio::sync::mpsc::Sender<${2:Mensaje}>,
	}

	impl ${1:ActorHandle} {
		async fn consultar(&self) -> ${3:Tipo} {
			let (tx, rx) = tokio::sync::oneshot::channel();
			self.emisor.send(${2:Mensaje}::Consultar { respuesta: tx }).await.ok();
			${0:rx.await.unwrap()}
		}
	}

snippet pat-nullobject "null object: implementacion neutra de un trait en vez de Option<Box<dyn Trait>>"
	struct ${1:SinOperacion};

	impl ${2:Trait} for ${1:SinOperacion} {
		fn ${3:ejecutar}(&self) {
			${0}
		}
	}

snippet pat-memento "memento: capturar y restaurar el estado interno de un objeto"
	#[derive(Clone)]
	struct ${1:Memento} {
		estado: ${2:Tipo},
	}

	impl ${3:Originador} {
		fn guardar(&self) -> ${1:Memento} {
			${1:Memento} { estado: self.estado.clone() }
		}

		fn restaurar(&mut self, memento: ${1:Memento}) {
			${0:self.estado = memento.estado;}
		}
	}
