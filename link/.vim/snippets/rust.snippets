snippet sig-window "ventana de Hamming aplicada a un buffer" b
	fn ventana_hamming(n: usize) -> Vec<f64> {
		(0..n)
			.map(|i| 0.54 - 0.46 * (2.0 * std::f64::consts::PI * i as f64 / (n as f64 - 1.0)).cos())
			.collect()
	}

	let ${1:senal_ventaneada}: Vec<f64> = ${2:senal}
		.iter()
		.zip(ventana_hamming(${2:senal}.len()))
		.map(|(s, w)| s * w)
		.collect();
	${0}

