snippet trc-opentelemetry "exportar spans a un backend OTLP (Jaeger/Tempo/etc.)" b
	use opentelemetry::trace::TracerProvider as _;
	use tracing_subscriber::{layer::SubscriberExt, util::SubscriberInitExt};

	fn init_tracing_otel() -> anyhow::Result<()> {
		let proveedor = opentelemetry_otlp::new_pipeline()
			.tracing()
			.with_exporter(opentelemetry_otlp::new_exporter().tonic())
			.install_batch(opentelemetry_sdk::runtime::Tokio)?;

		let capa_otel = tracing_opentelemetry::layer().with_tracer(
			proveedor.tracer("${1:mi-servicio}"),
		);

		tracing_subscriber::registry()
			.with(tracing_subscriber::EnvFilter::from_default_env())
			.with(tracing_subscriber::fmt::layer())
			.with(capa_otel)
			.try_init()?;
		${0:Ok(())}
	}

