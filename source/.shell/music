fl_midindex(){
find -iname '*.mid' -or -iname '*.midi' | while read line; do bn="$(basename "$line" | sed -e 's/.MID//g' -e 's/.MIDI//g' -e 's/.mid//g' -e 's/.midi//g')"; n=1; dst="${bn}.mid"; while [ -e ~/squashfs/partial/"$dst" ]; do n=$(( $n + 1 )); dst="${bn}_${n}.mid"; done; cp "$line" ~/squashfs/partial/"$dst"; echo "{\"path\": \"$line\", \"id\": \"$dst\"}" >> ~/squashfs/index; done
}

fl_mdsplit(){
ls | while read line; do md=$(echo $line | md5sum - | sed 's/^\(..\).*/\1/g'); mkdir -p ~/squashfs/final/$md; mv -- "$line" ~/squashfs/final/$md; done
}

