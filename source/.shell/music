musescore_extract(){
msc_mgrep () {
    echo -n cat $1 > /tmp/script
    shift
    for a in $*
    do
        if [ "$a" = "+" ]
        then
            echo >> /tmp/script
            echo -n cat $1 >> /tmp/script
        else
            echo -n " | grep -i $a" >> /tmp/script
        fi
    done
    source /tmp/script
}

